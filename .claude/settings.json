{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "mcp__github__*"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "powershell -NonInteractive -File \"${CLAUDE_PROJECT_DIR}/.claude/hooks/check-secrets-on-commit.ps1\""
          }
        ]
      }
    ]
  }
}
