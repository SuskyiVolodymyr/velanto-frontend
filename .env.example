NEXT_PUBLIC_API_URL=http://localhost:3001
# Public base URL for rendering uploaded media (pack image items store an S3
# key; the render URL is this base + the key). Points at the CloudFront/S3
# distribution — must match the backend's S3_PUBLIC_BASE_URL. Leave unset in
# local dev if you aren't exercising image items.
NEXT_PUBLIC_MEDIA_BASE_URL=

# Production URL of the site, used for canonical/sitemap/robots/OG URLs. Falls
# back to https://playvelanto.com when unset.
# NEXT_PUBLIC_SITE_URL=https://playvelanto.com

# Error/performance monitoring (Sentry). All OPTIONAL — without a DSN, Sentry is
# not initialized (no-op) and the build is unaffected (the Sentry build plugin
# only engages when NEXT_PUBLIC_SENTRY_DSN is set). Set these from your Sentry
# project in production. NEXT_PUBLIC_* vars are exposed to the browser bundle;
# the bare (server) counterparts cover SSR / server components / route handlers.
# NEXT_PUBLIC_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
# SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
#
# Environment tag (dev vs prod) used to filter issues in Sentry. Defaults to
# NODE_ENV ("development" locally, "production" in a prod build); override for
# preview/staging.
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
# SENTRY_ENVIRONMENT=production
#
# Kill switch — set to "false" to silence Sentry (e.g. locally) WITHOUT removing
# the DSN. Anything else (or unset) keeps it enabled.
# NEXT_PUBLIC_SENTRY_ENABLED=false
# SENTRY_ENABLED=false
#
# Trace sample rate (performance). Defaults to 1.0 outside production and 0.1 in
# production; set explicitly to override (e.g. 0 to disable tracing entirely).
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_TRACES_SAMPLE_RATE=0.1
#
# Source-map upload (readable stack traces) — only when building for prod:
# SENTRY_ORG=your-org
# SENTRY_PROJECT=velanto-frontend
# SENTRY_AUTH_TOKEN=sntrys_...
